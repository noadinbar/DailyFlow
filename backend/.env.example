AWS_REGION=us-east-1

USERS_TABLE=Users
INTEGRATIONS_TABLE=Integrations
BUSY_BLOCKS_TABLE=BusyBlocks
DAILYFLOW_CALENDER_TABLE=DailyFlowCalender

COGNITO_USER_POOL_ID=us-east-1_your_user_pool_id
COGNITO_APP_CLIENT_ID=your_cognito_app_client_id

GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
# Must match a Google Cloud "Authorized redirect URI" exactly (backend callback, not the SPA).
GOOGLE_REDIRECT_URI=https://YOUR_API_ID.execute-api.us-east-1.amazonaws.com/auth/google/callback
# Used after Google OAuth completes to send the user back to the SPA calendar route.
FRONTEND_APP_URL=https://main.dnp9vhzk0bw8l.amplifyapp.com
